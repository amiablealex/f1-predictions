# =============================================================================
# F1 Predictions — environment configuration
# Copy this file to `.env` for local development.
# In production (Railway), set these as service variables instead.
# =============================================================================

# Flask
FLASK_ENV=development                       # development | production
SECRET_KEY=change-me-to-a-long-random-string

# Database
# Railway will inject DATABASE_URL automatically when Postgres plugin is added.
# For local Pi development, point this at your local Postgres instance.
DATABASE_URL=postgresql://f1user:f1pass@localhost:5432/f1predictions

# Resend (transactional email — only used for password reset)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=F1 Predictions

# App URL (used in password reset emails)
APP_BASE_URL=http://localhost:5000

# Jolpica F1 API (no key required — rate limit is 4 req/s, 500/hr)
JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1
JOLPICA_USER_AGENT=f1-predictions/1.0

# F1 season to track (set explicitly to avoid surprises at year boundary)
F1_SEASON=2026

# Worker behaviour
SCHEDULER_TIMEZONE=Europe/London
RESULTS_POLL_INTERVAL_MINUTES=5
SCHEDULE_SYNC_INTERVAL_HOURS=12
RESULTS_PENDING_TIMEOUT_HOURS=6

# Admin bootstrap (used on first run only — creates an admin user if none exists)
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
